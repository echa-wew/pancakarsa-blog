---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentPost: CollectionEntry<'blog'>;
	limit?: number;
}

const { currentPost, limit = 3 } = Astro.props;

// Get all posts except current
const allPosts = (await getCollection('blog'))
	.filter((post) => post.id !== currentPost.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Calculate similarity score based on shared tags
const postsWithScore = allPosts.map((post) => {
	const sharedTags = post.data.tags.filter((tag) => currentPost.data.tags.includes(tag));
	const categoryMatch = post.data.category === currentPost.data.category ? 1 : 0;
	const score = sharedTags.length + categoryMatch;
	return { post, score };
});

// Get top posts by score, fallback to recent if no matches
const relatedPosts = postsWithScore
	.filter((p) => p.score > 0)
	.sort((a, b) => b.score - a.score)
	.slice(0, limit)
	.map((p) => p.post);

// If not enough related posts, fill with recent posts
if (relatedPosts.length < limit) {
	const remaining = limit - relatedPosts.length;
	const recentPosts = allPosts
		.filter((post) => !relatedPosts.includes(post))
		.slice(0, remaining);
	relatedPosts.push(...recentPosts);
}
---

{
	relatedPosts.length > 0 && (
		<section class="related-posts">
			<h2>Artikel Terkait</h2>
			<div class="posts-grid">
				{relatedPosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="related-post-card">
						<div class="card-content">
							<h3>{post.data.title}</h3>
							<p class="description">{post.data.description}</p>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.category && (
									<span class="category-badge">{post.data.category}</span>
								)}
							</p>
						</div>
					</a>
				))}
			</div>
		</section>
	)
}

<style>
	.related-posts {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 2px solid rgb(var(--gray-light));
	}
	h2 {
		margin-bottom: 1.5rem;
		color: rgb(var(--gray-dark));
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}
	.related-post-card {
		display: block;
		padding: 1.5rem;
		background: rgb(var(--gray-light));
		border-radius: 8px;
		text-decoration: none;
		transition: all 0.2s;
	}
	.related-post-card:hover {
		background: rgb(var(--gray));
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(var(--black), 0.1);
	}
	.card-content h3 {
		margin: 0 0 0.5rem 0;
		font-size: 1.1rem;
		color: rgb(var(--black));
		line-height: 1.3;
	}
	.description {
		margin: 0 0 1rem 0;
		font-size: 0.9rem;
		color: rgb(var(--gray-dark));
		line-height: 1.5;
	}
	.meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}
	.category-badge {
		background: rgb(var(--accent));
		color: white;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		font-size: 0.75rem;
		text-transform: capitalize;
	}
	@media (max-width: 720px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>