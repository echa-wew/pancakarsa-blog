---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group posts by year and month
const postsByYearMonth: Record<string, Record<string, typeof posts>> = {};

posts.forEach((post) => {
	const date = new Date(post.data.pubDate);
	const year = date.getFullYear().toString();
	const month = date.toLocaleDateString('id-ID', { month: 'long' });

	if (!postsByYearMonth[year]) {
		postsByYearMonth[year] = {};
	}
	if (!postsByYearMonth[year][month]) {
		postsByYearMonth[year][month] = [];
	}
	postsByYearMonth[year][month].push(post);
});

// Sort years descending
const years = Object.keys(postsByYearMonth).sort((a, b) => parseInt(b) - parseInt(a));

// Month order for sorting
const monthOrder = [
	'Januari',
	'Februari',
	'Maret',
	'April',
	'Mei',
	'Juni',
	'Juli',
	'Agustus',
	'September',
	'Oktober',
	'November',
	'Desember',
];
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`Arsip - ${SITE_TITLE}`} description="Arsip artikel berdasarkan waktu" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			h1 {
				margin-bottom: 2em;
			}
			.year-section {
				margin-bottom: 3em;
			}
			.year-title {
				font-size: 2rem;
				color: rgb(var(--accent));
				margin-bottom: 1em;
				border-bottom: 2px solid rgb(var(--gray-light));
				padding-bottom: 0.5em;
			}
			.month-section {
				margin-bottom: 2em;
				padding-left: 1em;
			}
			.month-title {
				font-size: 1.3rem;
				color: rgb(var(--gray-dark));
				margin-bottom: 0.5em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item {
				padding: 0.75em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-item:last-child {
				border-bottom: none;
			}
			.post-link {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				text-decoration: none;
				color: rgb(var(--black));
				transition: color 0.2s;
				gap: 1em;
			}
			.post-link:hover {
				color: rgb(var(--accent));
			}
			.post-title {
				flex: 1;
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				white-space: nowrap;
			}
			.post-count {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin-left: 0.5em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Arsip Artikel</h1>

			{
				years.map((year) => {
					const months = Object.keys(postsByYearMonth[year]).sort(
						(a, b) => monthOrder.indexOf(b) - monthOrder.indexOf(a),
					);

					const yearTotal = Object.values(postsByYearMonth[year]).flat().length;

					return (
						<div class="year-section">
							<h2 class="year-title">
								{year}
								<span class="post-count">({yearTotal} artikel)</span>
							</h2>
							{months.map((month) => {
								const monthPosts = postsByYearMonth[year][month];
								return (
									<div class="month-section">
										<h3 class="month-title">
											{month}
											<span class="post-count">({monthPosts.length})</span>
										</h3>
										<ul class="post-list">
											{monthPosts.map((post) => (
												<li class="post-item">
													<a href={`/blog/${post.id}/`} class="post-link">
														<span class="post-title">{post.data.title}</span>
														<span class="post-date">
															{post.data.pubDate.toLocaleDateString('id-ID', {
																day: 'numeric',
																month: 'short',
															})}
														</span>
													</a>
												</li>
											))}
										</ul>
									</div>
								);
							})}
						</div>
					);
				})
			}
		</main>
		<Footer />
	</body>
</html>